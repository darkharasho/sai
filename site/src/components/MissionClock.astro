---
const phrases = [
  'LOCKING TELEMETRY',
  'BREACHING ICE',
  'INDEXING REPOSITORY',
  'NEGOTIATING HANDSHAKE',
  'SPOOLING CONTEXT',
  'AUTHORIZING APPROVALS',
  'STREAMING TOKENS',
  'COMPILING DIFFS',
  'PARSING DIRECTIVE',
  'ROUTING TO MODEL',
];
const providers = ['CLAUDE/SONNET-4', 'CODEX/GPT-5', 'GEMINI/PRO-2.5'];
---
<div class="clock" role="img" aria-label="SAI mission-clock telemetry">
  <header class="clock-chrome">
    <span class="dots">
      <span class="d d-r"></span><span class="d d-y"></span><span class="d d-g"></span>
    </span>
    <span class="title">sai · session 001 · agent.live</span>
    <span class="sig" data-sig>SIG ●●●●○</span>
  </header>

  <div class="screen">
    <img class="drift-logo" src={`${import.meta.env.BASE_URL}img/sai.png`} alt="" aria-hidden="true" />
    <span class="scan" aria-hidden="true"></span>

    <ol class="readout">
      <li class="row hot">
        <span class="ts tabnum" data-clock>[00:00.0]</span>
        <span class="phrase" data-phrase>{phrases[0]}</span>
        <span class="cursor" aria-hidden="true">▌</span>
      </li>
      <li class="row">
        <span class="ts tabnum">[T-00:00]</span>
        <span class="k">PROVIDER</span>
        <span class="v" data-provider>{providers[0]}</span>
      </li>
      <li class="row">
        <span class="ts tabnum">[T-00:00]</span>
        <span class="k">CONTEXT</span>
        <span class="v"><span class="bar"><span class="bar-fill" data-ctx></span></span> <span data-ctx-pct>62%</span></span>
      </li>
      <li class="row">
        <span class="ts tabnum">[T-00:00]</span>
        <span class="k">TOKENS / SEC</span>
        <span class="v tabnum" data-tps>184</span>
      </li>
      <li class="row dim">
        <span class="ts tabnum">[T-00:00]</span>
        <span class="k">APPROVAL</span>
        <span class="v ok">AUTO · low-risk</span>
      </li>
      <li class="row dim">
        <span class="ts tabnum">[T-00:00]</span>
        <span class="k">QUEUE</span>
        <span class="v">02 pending → 01 next</span>
      </li>
    </ol>

    <footer class="prompt">
      <span class="caret">$</span>
      <span class="typed" data-typed></span>
      <span class="cursor" aria-hidden="true">▌</span>
    </footer>
  </div>
</div>

<script is:inline define:vars={{ phrases, providers }}>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const clockEl = document.querySelector('[data-clock]');
  const phraseEl = document.querySelector('[data-phrase]');
  const provEl = document.querySelector('[data-provider]');
  const ctxEl = document.querySelector('[data-ctx]');
  const ctxPctEl = document.querySelector('[data-ctx-pct]');
  const tpsEl = document.querySelector('[data-tps]');
  const sigEl = document.querySelector('[data-sig]');
  const typedEl = document.querySelector('[data-typed]');

  const promptScript = [
    'refactor the queue scheduler',
    'add a dark-mode toggle to settings',
    'fix the off-by-one in markdown preview',
    'wire mcp servers into the sidebar',
    'write tests for the diff viewer',
  ];

  if (reduced) {
    clockEl && (clockEl.textContent = '[00:12.4]');
    phraseEl && (phraseEl.textContent = phrases[0]);
    typedEl && (typedEl.textContent = promptScript[0]);
    if (ctxEl) ctxEl.style.width = '62%';
  } else {
    // Mission clock
    if (clockEl) {
      const start = performance.now();
      const tick = (now) => {
        const elapsed = (now - start) / 1000;
        const m = Math.floor(elapsed / 60);
        const s = Math.floor(elapsed % 60);
        const d = Math.floor((elapsed * 10) % 10);
        clockEl.textContent = `[${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}.${d}]`;
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    // Phrase rotator
    if (phraseEl) {
      let i = 0;
      setInterval(() => {
        i = (i + 1) % phrases.length;
        phraseEl.textContent = phrases[i];
      }, 1800);
    }

    // Provider rotator
    if (provEl) {
      let p = 0;
      setInterval(() => {
        p = (p + 1) % providers.length;
        provEl.textContent = providers[p];
      }, 4200);
    }

    // Context bar / tokens-per-sec drift
    if (ctxEl && ctxPctEl) {
      let pct = 62;
      setInterval(() => {
        pct += (Math.random() - 0.5) * 6;
        pct = Math.max(28, Math.min(94, pct));
        ctxEl.style.width = pct.toFixed(0) + '%';
        ctxPctEl.textContent = pct.toFixed(0) + '%';
      }, 900);
    }
    if (tpsEl) {
      setInterval(() => {
        tpsEl.textContent = String(120 + Math.floor(Math.random() * 110));
      }, 700);
    }

    // Signal bars
    if (sigEl) {
      const states = ['SIG ●●●●○', 'SIG ●●●●●', 'SIG ●●●○○', 'SIG ●●●●○'];
      let s = 0;
      setInterval(() => { s = (s + 1) % states.length; sigEl.textContent = states[s]; }, 1500);
    }

    // Typewriter on the prompt line — cycles
    if (typedEl) {
      let idx = 0, ch = 0, dir = 1;
      const step = () => {
        const target = promptScript[idx];
        if (dir > 0) {
          ch++;
          if (ch >= target.length) { dir = -1; setTimeout(step, 1600); return; }
        } else {
          ch--;
          if (ch <= 0) { dir = 1; idx = (idx + 1) % promptScript.length; setTimeout(step, 400); return; }
        }
        typedEl.textContent = target.slice(0, ch);
        setTimeout(step, dir > 0 ? 55 : 30);
      };
      step();
    }
  }
</script>

<style>
  .clock {
    background: linear-gradient(180deg, #0c1114 0%, #0a0d0f 100%);
    border: 1px solid var(--rule-2);
    box-shadow:
      inset 0 0 0 1px rgba(255, 180, 84, 0.08),
      0 40px 100px -40px rgba(255, 180, 84, 0.35),
      0 0 80px -20px rgba(255, 180, 84, 0.15);
    font-family: var(--mono);
    overflow: hidden;
  }
  .clock-chrome {
    display: flex; align-items: center; gap: 14px;
    padding: 11px 16px;
    background: #08090b;
    border-bottom: 1px solid var(--rule-2);
    font-size: 11px;
    color: var(--phosphor-dim);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .dots { display: inline-flex; gap: 6px; }
  .d { width: 9px; height: 9px; border-radius: 50%; display: inline-block; opacity: 0.7; }
  .d-r { background: var(--red); }
  .d-y { background: var(--phosphor); }
  .d-g { background: var(--green); }
  .title { letter-spacing: 0.08em; }
  .sig { margin-left: auto; font-variant-numeric: tabular-nums; color: var(--phosphor); }

  .screen {
    position: relative;
    padding: 28px 28px 0;
    min-height: 360px;
  }
  .drift-logo {
    position: absolute;
    top: 50%; left: 50%;
    width: 320px; height: 320px;
    max-width: 80%;
    object-fit: contain;
    transform: translate(-50%, -50%);
    opacity: 0.10;
    pointer-events: none;
    filter: brightness(1.2) saturate(0.8) drop-shadow(0 0 20px var(--phosphor-glow));
    animation: drift-spin 22s ease-in-out infinite, drift-pulse 4s ease-in-out infinite;
  }
  @keyframes drift-spin {
    0%   { transform: translate(-50%, -50%) rotate(0deg) scale(1); }
    50%  { transform: translate(-50%, -50%) rotate(180deg) scale(1.08); }
    100% { transform: translate(-50%, -50%) rotate(360deg) scale(1); }
  }
  @keyframes drift-pulse {
    0%, 100% { opacity: 0.07; }
    50%      { opacity: 0.14; }
  }
  @media (prefers-reduced-motion: reduce) {
    .drift-logo { animation: none; opacity: 0.08; }
  }
  .scan {
    position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 3px,
      rgba(0,0,0,0.20) 3px,
      rgba(0,0,0,0.20) 4px
    );
    mix-blend-mode: multiply;
  }

  .readout {
    position: relative;
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 12px;
    font-size: 13px;
  }
  .row {
    display: grid;
    grid-template-columns: 86px 110px 1fr auto;
    align-items: baseline;
    column-gap: 14px;
  }
  .row.hot { grid-template-columns: 86px 1fr auto; }
  .ts { white-space: nowrap; }
  .row.dim { color: var(--phosphor-dim); }
  .ts { color: var(--phosphor); opacity: 0.85; }
  .row.dim .ts { color: var(--phosphor-dim); }
  .k { color: var(--phosphor-dim); text-transform: uppercase; letter-spacing: 0.16em; font-size: 11px; }
  .v { color: var(--phosphor-2); }
  .v.ok { color: var(--green); }
  .phrase {
    color: var(--phosphor);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 600;
  }
  .cursor { color: var(--phosphor); animation: blink 1s steps(2, start) infinite; }

  .bar {
    display: inline-block; width: 120px; height: 8px;
    background: rgba(255,180,84,0.12);
    border: 1px solid var(--phosphor-dim);
    vertical-align: middle;
    position: relative;
    margin-right: 8px;
  }
  .bar-fill {
    display: block; height: 100%;
    background: var(--phosphor);
    width: 62%;
    transition: width 700ms ease;
    background-image: repeating-linear-gradient(
      45deg, rgba(0,0,0,0.18) 0 3px, transparent 3px 6px
    );
  }

  .prompt {
    margin: 22px -28px 0;
    padding: 16px 28px;
    border-top: 1px dashed var(--rule-2);
    background: rgba(0,0,0,0.25);
    display: flex; gap: 10px; align-items: center;
    font-size: 13px;
    color: var(--phosphor-2);
    position: relative; z-index: 2;
  }
  .caret { color: var(--phosphor); }
  .typed { white-space: nowrap; overflow: hidden; }

  @media (max-width: 720px) {
    .screen { padding: 22px 18px 0; }
    .row { grid-template-columns: 60px 90px 1fr; }
    .row.hot { grid-template-columns: 60px 1fr auto; }
    .prompt { margin: 22px -18px 0; padding: 14px 18px; }
    .drift { font-size: 7rem; }
  }
</style>
