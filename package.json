{
  "name": "sai",
  "version": "0.3.1",
  "description": "AI-First Code Editor",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "vite --no-sandbox",
    "dist": "vite build && electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.sai.app",
    "productName": "SAI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "public/img/sai.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/img/sai.png"
    },
    "publish": {
      "provider": "github",
      "owner": "darkharasho",
      "repo": "sai"
    },
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "diff2html": "^3.4.56",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
