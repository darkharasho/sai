---
import FeatureCard from './FeatureCard.astro';
import { features } from '../data/features';

const flagships = features.filter(f => f.flagship);
const rest = features.filter(f => !f.flagship);
---
<section class="sec sec--console feat" aria-labelledby="feat-title">
  <div class="container">
    <div class="head">
      <p class="eyebrow">Schedule 04 · MODULE INVENTORY</p>
      <h2 id="feat-title" class="head-title">
        <span class="mono">Two flagships.</span>
        <span class="display">Eight supporting modules.</span>
      </h2>
      <p class="head-lede">
        Every part of the SAI cockpit is built for the agent loop — prompt,
        review, run, ship. Nothing bolted on. Nothing in the way.
      </p>
    </div>

    {flagships.length > 0 && (
      <div class="grid grid--flagship">
        {flagships.map((f, i) => (
          <FeatureCard coord={f.coord} title={f.title} blurb={f.blurb} meta={f.meta} icon={f.icon} index={i} flagship={true} />
        ))}
      </div>
    )}

    <div class="grid">
      {rest.map((f, i) => (
        <FeatureCard coord={f.coord} title={f.title} blurb={f.blurb} meta={f.meta} icon={f.icon} index={i + flagships.length} />
      ))}
    </div>

    <p class="legend">
      <span>LEGEND ·</span>
      <span><span class="sw a"></span> A-series · flagship</span>
      <span><span class="sw b"></span> B-series · agent loop</span>
      <span><span class="sw c"></span> C-series · workspace</span>
      <span><span class="sw d"></span> D-series · extensibility</span>
    </p>
  </div>
</section>

<style>
  .feat { padding-bottom: 140px; }
  .head { max-width: 880px; margin-bottom: 56px; }
  .head-title { display: grid; gap: 4px; font-size: clamp(2rem, 4.6vw, 3.8rem); line-height: 1; }
  .head-title .mono { font-family: var(--mono); font-weight: 700; color: var(--phosphor); letter-spacing: -0.02em; }
  .head-title .display { font-family: var(--display); font-style: italic; color: var(--phosphor-2); font-weight: 400; letter-spacing: -0.015em; }
  .head-lede { margin-top: 22px; max-width: 60ch; color: var(--phosphor-2); font-size: 14px; line-height: 1.7; }

  .grid--flagship {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--rule-2);
    margin-bottom: 0;
  }
  .grid--flagship > :global(.card) { border: none; border-right: 1px solid var(--rule-2); }
  .grid--flagship > :global(.card:last-child) { border-right: none; }
  .grid--flagship + .grid { border-top: none; }

  @media (max-width: 640px) {
    .grid--flagship { grid-template-columns: 1fr; }
    .grid--flagship > :global(.card) { border-right: none !important; border-bottom: 1px solid var(--rule-2) !important; }
    .grid--flagship > :global(.card:last-child) { border-bottom: none !important; }
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--rule-2);
  }
  .grid > :global(.card) { border: none; border-right: 1px solid var(--rule-2); border-bottom: 1px solid var(--rule-2); }
  .grid > :global(.card:nth-child(4n)) { border-right: none; }
  .grid > :global(.card:nth-last-child(-n+4)) { border-bottom: none; }

  .legend {
    margin-top: 28px;
    display: flex; gap: 28px; flex-wrap: wrap;
    font-family: var(--mono); font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--phosphor-dim);
  }
  .legend .sw { display: inline-block; width: 10px; height: 10px; margin-right: 8px; vertical-align: -1px; border: 1px solid var(--phosphor-dim); }
  .legend .sw.a { background: var(--phosphor); border-color: var(--phosphor); box-shadow: 0 0 0 2px var(--ink-2), 0 0 0 3px var(--phosphor); margin-right: 12px; }
  .legend .sw.b { background: var(--phosphor); border-color: var(--phosphor); }
  .legend .sw.c { background: var(--green); border-color: var(--green); }
  .legend .sw.d { background: var(--blue); border-color: var(--blue); }

  @media (max-width: 1100px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
    .grid > :global(.card) { border-right: 1px solid var(--rule-2); border-bottom: 1px solid var(--rule-2); }
    .grid > :global(.card:nth-child(2n)) { border-right: none; }
    .grid > :global(.card:nth-last-child(-n+2)) { border-bottom: none; }
    .grid > :global(.card:nth-child(4n)) { border-right: none; }
  }
  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
    .grid > :global(.card) { border-right: none !important; border-bottom: 1px solid var(--rule-2) !important; }
    .grid > :global(.card:last-child) { border-bottom: none !important; }
  }
</style>
