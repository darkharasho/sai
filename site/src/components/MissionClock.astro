---
const phrases = [
  'LOCKING TELEMETRY',
  'BREACHING ICE',
  'INDEXING REPOSITORY',
  'NEGOTIATING HANDSHAKE',
  'SPOOLING CONTEXT',
  'AUTHORIZING APPROVALS',
  'STREAMING TOKENS',
  'COMPILING DIFFS',
  'PARSING DIRECTIVE',
  'ROUTING TO MODEL',
];
const userPrompts = [
  'refactor the queue scheduler',
  'add a dark-mode toggle to settings',
  'fix the off-by-one in markdown preview',
  'wire mcp servers into the sidebar',
  'write tests for the diff viewer',
];
---
<div class="clock" role="img" aria-label="SAI thinking animation">
  <header class="clock-chrome">
    <span class="dots">
      <span class="d d-r"></span><span class="d d-y"></span><span class="d d-g"></span>
    </span>
    <span class="title">sai · session 001</span>
    <span class="badge">claude · sonnet</span>
  </header>

  <div class="screen">
    <img class="drift-logo" src={`${import.meta.env.BASE_URL}img/sai.png`} alt="" aria-hidden="true" />
    <span class="scan" aria-hidden="true"></span>

    <div class="chat">
      <div class="msg user">
        <span class="who">you</span>
        <span class="body" data-user-msg>{userPrompts[0]}</span>
      </div>

      <div class="msg assistant">
        <span class="who">sai</span>
        <span class="thinking">
          <span class="ts tabnum" data-clock>[00:00.0]</span>
          <span class="phrase" data-phrase>{phrases[0]}</span>
          <span class="cursor" aria-hidden="true">▌</span>
        </span>
      </div>
    </div>

    <form class="prompt" onsubmit="return false">
      <span class="caret">›</span>
      <span class="input" data-typed></span>
      <span class="cursor input-cursor" aria-hidden="true">▌</span>
      <span class="kbd">⏎</span>
    </form>
  </div>
</div>

<script is:inline define:vars={{ phrases, userPrompts }}>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const clockEl = document.querySelector('[data-clock]');
  const phraseEl = document.querySelector('[data-phrase]');
  const userMsgEl = document.querySelector('[data-user-msg]');
  const typedEl = document.querySelector('[data-typed]');

  const nextDrafts = [
    'show me the diff for the last commit',
    'open the terminal in /src',
    'rename getCwd to getCurrentWorkingDirectory',
    'add a follow-up: also update the readme',
    'queue: run the test suite when done',
  ];

  if (reduced) {
    clockEl && (clockEl.textContent = '[00:12.4]');
    phraseEl && (phraseEl.textContent = phrases[0]);
    typedEl && (typedEl.textContent = nextDrafts[0]);
  } else {
    // Mission clock
    if (clockEl) {
      const start = performance.now();
      const tick = (now) => {
        const elapsed = (now - start) / 1000;
        const m = Math.floor(elapsed / 60);
        const s = Math.floor(elapsed % 60);
        const d = Math.floor((elapsed * 10) % 10);
        clockEl.textContent = `[${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}.${d}]`;
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    // Phrase rotator
    if (phraseEl) {
      let i = 0;
      setInterval(() => {
        i = (i + 1) % phrases.length;
        phraseEl.textContent = phrases[i];
      }, 1800);
    }

    // User msg rotates slowly
    if (userMsgEl) {
      let u = 0;
      setInterval(() => {
        u = (u + 1) % userPrompts.length;
        userMsgEl.textContent = userPrompts[u];
      }, 6500);
    }

    // Typewriter on the input — cycles
    if (typedEl) {
      let idx = 0, ch = 0, dir = 1;
      const step = () => {
        const target = nextDrafts[idx];
        if (dir > 0) {
          ch++;
          if (ch >= target.length) { dir = -1; setTimeout(step, 1800); return; }
        } else {
          ch--;
          if (ch <= 0) { dir = 1; idx = (idx + 1) % nextDrafts.length; setTimeout(step, 500); return; }
        }
        typedEl.textContent = target.slice(0, ch);
        setTimeout(step, dir > 0 ? 55 : 28);
      };
      step();
    }
  }
</script>

<style>
  .clock {
    background: linear-gradient(180deg, #0c1114 0%, #0a0d0f 100%);
    border: 1px solid var(--rule-2);
    box-shadow:
      inset 0 0 0 1px rgba(255, 180, 84, 0.08),
      0 40px 100px -40px rgba(255, 180, 84, 0.35),
      0 0 80px -20px rgba(255, 180, 84, 0.15);
    font-family: var(--mono);
    overflow: hidden;
  }
  .clock-chrome {
    display: flex; align-items: center; gap: 14px;
    padding: 11px 16px;
    background: #08090b;
    border-bottom: 1px solid var(--rule-2);
    font-size: 11px;
    color: var(--phosphor-dim);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .dots { display: inline-flex; gap: 6px; }
  .d { width: 9px; height: 9px; border-radius: 50%; display: inline-block; opacity: 0.7; }
  .d-r { background: var(--red); }
  .d-y { background: var(--phosphor); }
  .d-g { background: var(--green); }
  .title { letter-spacing: 0.08em; }
  .badge {
    margin-left: auto;
    color: var(--phosphor);
    border: 1px solid var(--phosphor-dim);
    padding: 3px 8px;
    font-size: 10px;
    letter-spacing: 0.16em;
  }

  /* Screen is a flex column so the prompt can hard-pin to the bottom */
  .screen {
    position: relative;
    display: flex; flex-direction: column;
    min-height: 380px;
    padding: 0;
  }
  .drift-logo {
    position: absolute;
    top: 50%; left: 50%;
    width: 320px; height: 320px;
    max-width: 70%;
    object-fit: contain;
    transform: translate(-50%, -50%);
    opacity: 0.09;
    pointer-events: none;
    filter: brightness(1.2) saturate(0.8) drop-shadow(0 0 24px var(--phosphor-glow));
    animation: drift-spin 22s ease-in-out infinite, drift-pulse 4s ease-in-out infinite;
    z-index: 0;
  }
  @keyframes drift-spin {
    0%   { transform: translate(-50%, -50%) rotate(0deg) scale(1); }
    50%  { transform: translate(-50%, -50%) rotate(180deg) scale(1.08); }
    100% { transform: translate(-50%, -50%) rotate(360deg) scale(1); }
  }
  @keyframes drift-pulse {
    0%, 100% { opacity: 0.07; }
    50%      { opacity: 0.14; }
  }
  @media (prefers-reduced-motion: reduce) {
    .drift-logo { animation: none; opacity: 0.08; }
  }
  .scan {
    position: absolute; inset: 0; pointer-events: none; z-index: 1;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 3px,
      rgba(0,0,0,0.20) 3px,
      rgba(0,0,0,0.20) 4px
    );
    mix-blend-mode: multiply;
  }

  /* Chat: flex:1 so it grows; prompt at bottom uses margin-top:auto */
  .chat {
    position: relative;
    z-index: 2;
    flex: 1;
    padding: 28px 28px 20px;
    display: flex; flex-direction: column; gap: 18px;
    overflow: hidden;
  }
  .msg { display: grid; grid-template-columns: 60px 1fr; column-gap: 14px; align-items: baseline; }
  .who {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--phosphor-dim);
    padding-top: 2px;
  }
  .msg.user .body {
    color: var(--phosphor-2);
    font-size: 14px; line-height: 1.55;
  }
  .msg.user .body::before {
    content: "› ";
    color: var(--phosphor-dim);
  }
  .msg.assistant .who { color: var(--phosphor); }

  .thinking {
    display: inline-flex; align-items: baseline; gap: 12px;
    font-size: 14px;
  }
  .thinking .ts {
    color: var(--phosphor);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .thinking .phrase {
    color: var(--phosphor);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .cursor { color: var(--phosphor); animation: blink 1s steps(2, start) infinite; }

  /* Hard-locked to the bottom */
  .prompt {
    position: relative; z-index: 2;
    margin-top: auto;
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    column-gap: 10px;
    padding: 16px 22px;
    background: rgba(0, 0, 0, 0.35);
    border-top: 1px solid var(--rule-2);
    font-size: 13.5px;
    color: var(--phosphor-2);
  }
  .prompt .caret {
    color: var(--phosphor);
    font-size: 16px;
    line-height: 1;
  }
  .prompt .input {
    min-height: 1.4em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: clip;
  }
  .input-cursor { font-size: 14px; }
  .prompt .kbd {
    font-size: 10px;
    color: var(--phosphor-dim);
    border: 1px solid var(--phosphor-dim);
    padding: 3px 8px;
    letter-spacing: 0.16em;
  }

  @media (max-width: 720px) {
    .chat { padding: 22px 18px 14px; }
    .msg { grid-template-columns: 48px 1fr; column-gap: 10px; }
    .prompt { padding: 14px 18px; }
    .drift-logo { width: 240px; height: 240px; }
  }
</style>
