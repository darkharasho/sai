---
import { Icon } from 'astro-icon/components';
const releaseUrl = 'https://github.com/darkharasho/sai/releases/latest';
const platforms = [
  { os: 'Linux',   format: 'AppImage',  arch: 'x86_64 · arm64', tag: 'LIN-01' },
  { os: 'Windows', format: 'Installer', arch: 'x64',            tag: 'WIN-01' },
  { os: 'macOS',   format: 'DMG',       arch: 'arm64 · x64',    tag: 'MAC-01' },
];
---
<section class="sec sec--paper acq" aria-labelledby="dl-title" id="download">
  <div class="container">
    <div class="head">
      <p class="eyebrow">Manifest 05 · ACQUISITION</p>
      <h2 id="dl-title" class="head-title">
        <span class="mono">Three vectors.</span>
        <span class="display">One binary.</span>
      </h2>
      <p class="head-lede">
        Pick a payload for your machine. Single signed binary per platform —
        no installers chained to other installers, no telemetry funnel.
      </p>
    </div>

    <div class="tiles">
      {platforms.map((p) => (
        <a class="tile" href={releaseUrl}>
          <span class="tag">{p.tag}</span>
          <h3 class="os">{p.os}</h3>
          <div class="meta">
            <span class="fmt">{p.format}</span>
            <span class="arch">{p.arch}</span>
          </div>
          <div class="cta">
            <span class="cta-l"><Icon name="lucide:download" /> Pull payload</span>
            <span class="arrow"><Icon name="lucide:arrow-right" /></span>
          </div>
        </a>
      ))}
    </div>

    <div class="src">
      <div class="src-head">
        <p class="eyebrow">// Procedure 05.b · Build from source</p>
        <span class="hint">requires node 20+</span>
      </div>
      <pre><code><span class="c">$</span> git clone https://github.com/darkharasho/sai.git
<span class="c">$</span> cd sai
<span class="c">$</span> npm install
<span class="c">$</span> npm run electron:dev   <span class="cm"># or: npm run dist</span></code></pre>
    </div>
  </div>
</section>

<style>
  .acq { color: var(--paper-ink); }
  .head { max-width: 880px; margin-bottom: 56px; }
  .head .eyebrow { color: var(--paper-ink); }
  .head-title { display: grid; gap: 4px; font-size: clamp(2rem, 4.6vw, 3.8rem); line-height: 1; }
  .head-title .mono { font-family: var(--mono); font-weight: 700; letter-spacing: -0.02em; }
  .head-title .display { font-family: var(--display); font-style: italic; font-weight: 400; letter-spacing: -0.015em; color: #3b3024; }
  .head-lede { margin-top: 22px; max-width: 60ch; font-family: var(--mono); font-size: 14px; line-height: 1.7; color: #3b3024; }

  .tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 2px solid var(--paper-ink);
    border-bottom: 2px solid var(--paper-ink);
  }
  .tile {
    position: relative;
    padding: 28px 24px 24px;
    color: var(--paper-ink);
    text-decoration: none;
    background: transparent;
    transition: background 200ms, transform 200ms;
    display: flex; flex-direction: column; gap: 18px;
  }
  .tile + .tile { border-left: 1px solid var(--paper-ink); }
  .tile:hover { background: var(--paper-ink); color: var(--paper); }
  .tile:hover .arrow { transform: translateX(6px); }

  .tag {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--mono); font-size: 10px; font-weight: 700;
    letter-spacing: 0.22em; text-transform: uppercase;
    border: 1.5px solid currentColor;
    padding: 4px 10px;
  }
  .os {
    font-family: var(--display); font-style: italic; font-weight: 400;
    font-size: clamp(2.4rem, 4.4vw, 3.6rem);
    line-height: 0.95; letter-spacing: -0.02em;
    margin: 8px 0 0;
  }
  .meta {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.14em; text-transform: uppercase;
    display: flex; gap: 14px; flex-wrap: wrap;
  }
  .meta .fmt { font-weight: 700; }
  .meta .arch { opacity: 0.65; }
  .cta {
    margin-top: auto;
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 18px;
    border-top: 1px dashed currentColor;
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.16em; text-transform: uppercase;
  }
  .cta-l { display: inline-flex; align-items: center; gap: 8px; }
  .cta :global(svg) { width: 14px; height: 14px; stroke-width: 1.75; }
  .arrow { display: inline-flex; align-items: center; transition: transform 200ms; }
  .arrow :global(svg) { width: 18px; height: 18px; }

  .src { margin-top: 72px; }
  .src-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .src-head .eyebrow { color: var(--paper-ink); }
  .src-head .hint {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: #5d513f;
  }
  .src pre {
    background: var(--paper-ink); color: var(--paper);
    padding: 22px 24px;
    overflow-x: auto;
    font-family: var(--mono); font-size: 13px; line-height: 1.85;
    border: 1px solid var(--paper-ink);
    box-shadow: 6px 6px 0 0 #c8b48f;
  }
  .src pre .c { color: var(--phosphor); margin-right: 8px; }
  .src pre .cm { color: #8a7a5a; }

  @media (max-width: 880px) {
    .tiles { grid-template-columns: 1fr; }
    .tile + .tile { border-left: 0; border-top: 1px solid var(--paper-ink); }
  }
</style>
