---
import { Icon } from 'astro-icon/components';

interface Props {
  coord: string;
  title: string;
  blurb: string;
  meta: string;
  icon: string;
  index: number;
  flagship?: boolean;
}
const { coord, title, blurb, meta, icon, index, flagship = false } = Astro.props;
const n = String(index + 1).padStart(2, '0');
---
<article class={`card${flagship ? ' card--flagship' : ''}`} style={`--n: ${index}`}>
  <header class="hdr">
    <span class="coord">{coord}</span>
    <span class="n">№ {n}</span>
  </header>
  <span class="ic" aria-hidden="true">
    <Icon name={`lucide:${icon}`} />
  </span>
  <h3 class="t">{title}</h3>
  <p class="b">{blurb}</p>
  <footer class="ft">
    <span class="meta">{meta}</span>
    <span class="dot" aria-hidden="true">◆</span>
  </footer>
</article>

<style>
  .card {
    position: relative;
    padding: 28px 24px 22px;
    border: 1px solid var(--rule-2);
    background: linear-gradient(180deg, rgba(255,180,84,0.025), transparent 30%), var(--ink-2);
    color: var(--phosphor-2);
    overflow: hidden;
    transition: transform 200ms, border-color 200ms, background 200ms;
  }
  .card::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--phosphor);
    transform: scaleX(0); transform-origin: left;
    transition: transform 240ms ease;
  }
  .card:hover { transform: translateY(-2px); border-color: var(--phosphor-dim); background: linear-gradient(180deg, rgba(255,180,84,0.05), transparent 40%), var(--console); }
  .card:hover::before { transform: scaleX(1); }
  .card:hover .ic { color: var(--phosphor); transform: translateY(-1px); }

  .hdr {
    display: flex; align-items: center; justify-content: space-between;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--phosphor-dim);
    margin-bottom: 24px;
  }
  .coord {
    color: var(--phosphor);
    border: 1px solid var(--phosphor-dim);
    padding: 3px 8px;
    font-weight: 600;
  }
  .n { font-family: var(--display); font-style: italic; font-size: 18px; color: var(--phosphor-dim); letter-spacing: 0; }

  .ic {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px;
    color: var(--phosphor-2);
    margin-bottom: 18px;
    transition: color 180ms, transform 180ms;
  }
  .ic :global(svg) {
    width: 28px; height: 28px;
    stroke-width: 1.5;
  }

  .t {
    font-family: var(--mono);
    font-size: 17px;
    font-weight: 600;
    color: var(--phosphor);
    line-height: 1.25;
    letter-spacing: -0.005em;
    margin-bottom: 14px;
  }
  .b {
    margin: 0;
    font-family: var(--mono);
    font-size: 13px; line-height: 1.65;
    color: var(--phosphor-2);
    opacity: 0.78;
  }
  .ft {
    margin-top: 26px;
    padding-top: 14px;
    border-top: 1px dashed var(--rule-2);
    display: flex; align-items: center; justify-content: space-between;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--phosphor-dim);
  }
  .dot { color: var(--phosphor); font-size: 10px; }

  .card--flagship { background: linear-gradient(180deg, rgba(255,180,84,0.06), transparent 40%), var(--ink-2); }
  .card--flagship::before { transform: scaleX(1); height: 3px; }
  .card--flagship .coord { background: var(--phosphor); color: var(--ink); border-color: var(--phosphor); }
  .card--flagship .ic { color: var(--phosphor); }
  .card--flagship .t { font-size: 19px; }
</style>
