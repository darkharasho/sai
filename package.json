{
  "name": "sai",
  "version": "0.8.0",
  "description": "AI-First Code Editor",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "electron-rebuild -w node-pty",
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "vite --no-sandbox",
    "dist": "vite build && electron-builder --linux AppImage",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "dev:update": "node scripts/fake-update.js && vite",
    "dev:debug": "SAI_REMOTE_DEBUG=9222 vite"
  },
  "build": {
    "appId": "com.sai.app",
    "productName": "SAI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "public/img/sai.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/img/sai.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "public/img/sai.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "afterSign": "electron-builder-notarize",
    "publish": {
      "provider": "github",
      "owner": "darkharasho",
      "repo": "sai"
    },
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "diff2html": "^3.4.56",
    "electron-updater": "^6.8.3",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shell-quote": "^1.8.3",
    "shiki": "^4.0.2",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/shell-quote": "^1.7.5",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "electron-builder-notarize": "^1.5.2",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^4.1.2"
  }
}
