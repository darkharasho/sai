---
import { Icon } from 'astro-icon/components';
import SaiMark from './SaiMark.astro';
// Sourced from src/components/ThinkingAnimation.tsx — the real SAI word pool.
const phrases = [
  // mission-control / NASA
  'ESTABLISHING UPLINK', 'TRIANGULATING', 'CALIBRATING', 'TRACING SIGNAL',
  'ALIGNING VECTORS', 'MAPPING TOPOLOGY', 'LOCKING TELEMETRY', 'SYNCHRONIZING CLOCKS',
  'PRESSURIZING CABIN', 'VENTING COOLANT', 'PURGING MANIFOLDS', 'ARMING THRUSTERS',
  'DEPLOYING ANTENNA', 'STAGING BOOSTERS', 'CHECKING TELEMETRY', 'RUNNING DIAGNOSTICS',
  'CYCLING LIFE-SUPPORT', 'NEGOTIATING ORBIT', 'STAGING PAYLOAD', 'AWAITING GO/NO-GO',
  'SPINNING UP GYROS', 'SETTLING PROPELLANT', 'POLLING GROUND STATIONS', 'BURN COMPLETE',
  // cyberpunk / netrunner
  'JACKING IN', 'DECRYPTING TOKENS', 'SCRAPING CACHE', 'BREACHING ICE',
  'SPOOFING HANDSHAKE', 'ROUTING THROUGH PROXY', 'BURNING CYCLES', 'OVERCLOCKING CORE',
  'COMPILING SHELLCODE', 'CHASING DAEMONS', 'GHOSTING TRACE', 'FORGING PACKETS',
  'BYPASSING FIREWALL', 'SLOTTING CHROME', 'DUMPING REGISTERS', 'BLEEDING ENTROPY',
  // starship-computer / TNG
  'ACCESSING DATABANK', 'CROSS-REFERENCING', 'EXTRAPOLATING', 'COMPUTING VECTORS',
  'RESOLVING INTENT', 'INDEXING MEMORY', 'COMPILING THOUGHT', 'CONSULTING ARCHIVES',
  'POLARIZING HULL PLATING', 'REVERSING POLARITY', 'MODULATING SHIELDS',
  'RECALIBRATING SENSORS', 'HAILING FREQUENCIES', 'SCANNING SUBSPACE',
  // arcane / occult
  'CONSULTING THE ENTRAILS', 'CASTING RUNES', 'SCRYING THE BASIN', 'TRANSCRIBING SIGILS',
  'SUMMONING DAEMONS', 'BANISHING NULLS', 'DIVINING INTENT', 'CHANNELING SPIRITS',
  'BINDING ELEMENTALS', 'INKING WARDS', 'TURNING TAROT', 'INVOKING THE MUSE',
  // submarine / sonar
  'PINGING SONAR', 'TRIMMING BALLAST', 'RIGGING FOR QUIET', 'SOUNDING DEPTH',
  'PLOTTING HEADING', 'TRACKING CONTACT', 'BLOWING NEGATIVE', 'MAKING TURNS',
  // alchemy / lab
  'TITRATING REAGENTS', 'BALANCING EQUATIONS', 'CENTRIFUGING SAMPLES', 'STAINING SLIDES',
  'GROWING CULTURES', 'CRYSTALLIZING SOLUTE', 'DECANTING SUPERNATANT',
  // detective / noir
  'CHASING LEADS', 'RUNNING THE PLATES', 'DUSTING FOR PRINTS', 'TAILING THE SUSPECT',
  'PIECING TOGETHER ALIBIS', 'STAKING OUT THE BLOCK', 'CROSS-EXAMINING',
  // monastic / scriptorium
  'ILLUMINATING MARGINALIA', 'TRANSCRIBING CODICES', 'CONSULTING THE TOMES',
  'GRINDING PIGMENTS', 'ANNOTATING GLYPHS', 'BINDING THE FOLIO',
  // workshop / engineering
  'TIGHTENING TOLERANCES', 'TUNING HARMONICS', 'BLEEDING THE LINES',
  'TORQUING FASTENERS', 'SHIMMING THE BEARING', 'CALIBRATING JIGS',
  // food / kitchen pass
  'BLOOMING SPICES', 'REDUCING STOCK', 'TEMPERING CHOCOLATE', 'PROOFING DOUGH',
  'EMULSIFYING SAUCE', 'FLAMBÉING BRANDY', 'BASTING ROAST',
  // weather / oceanographic
  'TRACKING THE FRONT', 'CHARTING ISOBARS', 'READING THE TIDES',
  'TIMING THE LIGHTNING', 'TRIANGULATING STORMS',
  // aviation
  'RUNNING CHECKLIST', 'TRIMMING ELEVATORS', 'FEATHERING PROP', 'CYCLING LANDING GEAR',
  'WAITING FOR CLEARANCE', 'CONFIRMING APPROACH',
  // arcade / game
  'INSERTING COIN', 'LOADING NEXT LEVEL', 'SPAWNING ENEMIES', 'AWAITING PLAYER INPUT',
  'ROLLING SAVING THROW', 'SHUFFLING DECK', 'DEALING THE HAND',
  // pure absurdist
  'NEGOTIATING WITH THE COMPILER', 'BRIBING THE GARBAGE COLLECTOR',
  'WHISPERING TO THE LINKER', 'APOLOGIZING TO THE TYPECHECKER',
  'CONSULTING THE RUBBER DUCK', 'INTERROGATING THE STACK', 'BEGGING THE KERNEL',
];
const userPrompts = [
  'refactor the queue scheduler',
  'add a dark-mode toggle to settings',
  'fix the off-by-one in markdown preview',
  'wire mcp servers into the sidebar',
  'write tests for the diff viewer',
];
---
<div class="clock" role="img" aria-label="SAI thinking animation">
  <header class="clock-chrome">
    <span class="dots">
      <span class="d d-r"></span><span class="d d-y"></span><span class="d d-g"></span>
    </span>
    <span class="title">sai · session 001</span>
    <span class="badge">claude · sonnet</span>
  </header>

  <div class="screen">
    <SaiMark className="drift-logo" />
    <span class="scan" aria-hidden="true"></span>

    <div class="chat">
      <div class="msg user">
        <span class="who">you</span>
        <span class="body" data-user-msg>{userPrompts[0]}</span>
      </div>

      <div class="msg assistant">
        <span class="who">sai</span>
        <span class="thinking-animation">
          <img class="thinking-icon" src={`${import.meta.env.BASE_URL}img/sai.png`} alt="" aria-hidden="true" />
          <span class="thinking-clock tabnum" data-clock>[00:00.0]</span>
          <span class="thinking-text">
            <span data-phrase></span><span class="thinking-cursor-block" aria-hidden="true"></span>
          </span>
        </span>
      </div>
    </div>

    <form class="prompt" onsubmit="return false">
      <span class="caret">›</span>
      <span class="input" data-typed></span>
      <span class="cursor input-cursor" aria-hidden="true">▌</span>
      <span class="kbd" aria-label="press enter to send"><Icon name="lucide:corner-down-left" /></span>
    </form>
  </div>
</div>

<script is:inline define:vars={{ phrases, userPrompts }}>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const clockEl = document.querySelector('[data-clock]');
  const phraseEl = document.querySelector('[data-phrase]');
  const userMsgEl = document.querySelector('[data-user-msg]');
  const typedEl = document.querySelector('[data-typed]');

  const nextDrafts = [
    'show me the diff for the last commit',
    'open the terminal in /src',
    'rename getCwd to getCurrentWorkingDirectory',
    'add a follow-up: also update the readme',
    'queue: run the test suite when done',
  ];

  if (reduced) {
    clockEl && (clockEl.textContent = '[00:12.4]');
    phraseEl && (phraseEl.textContent = 'LOCKING TELEMETRY');
    typedEl && (typedEl.textContent = nextDrafts[0]);
  } else {
    // Mission clock
    if (clockEl) {
      const start = performance.now();
      const tick = (now) => {
        const elapsed = (now - start) / 1000;
        const m = Math.floor(elapsed / 60);
        const s = Math.floor(elapsed % 60);
        const d = Math.floor((elapsed * 10) % 10);
        clockEl.textContent = `[${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}.${d}]`;
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    // Typewriter phrase loop — matches src/components/ThinkingAnimation.tsx:
    //   type char-by-char (~40+rand 30ms), pause ~1200+rand 600ms,
    //   erase (~20ms/char), then pick a new word (skipping a random 0-2 ahead).
    if (phraseEl) {
      let wordIdx = Math.floor(Math.random() * phrases.length);
      let ch = 0;
      let phase = 'typing'; // 'typing' | 'pause' | 'erasing'
      const step = () => {
        const word = phrases[wordIdx % phrases.length];
        if (phase === 'typing') {
          if (ch < word.length) {
            ch++;
            phraseEl.textContent = word.slice(0, ch);
            setTimeout(step, 40 + Math.random() * 30);
          } else {
            phase = 'pause';
            setTimeout(step, 1200 + Math.random() * 600);
          }
        } else if (phase === 'pause') {
          phase = 'erasing';
          setTimeout(step, 100);
        } else {
          if (ch > 0) {
            ch--;
            phraseEl.textContent = word.slice(0, ch);
            setTimeout(step, 20);
          } else {
            wordIdx = (wordIdx + 1 + Math.floor(Math.random() * 3)) % phrases.length;
            phase = 'typing';
            setTimeout(step, 60);
          }
        }
      };
      step();
    }

    // User msg rotates slowly
    if (userMsgEl) {
      let u = 0;
      setInterval(() => {
        u = (u + 1) % userPrompts.length;
        userMsgEl.textContent = userPrompts[u];
      }, 6500);
    }

    // Typewriter on the input — cycles
    if (typedEl) {
      let idx = 0, ch = 0, dir = 1;
      const step = () => {
        const target = nextDrafts[idx];
        if (dir > 0) {
          ch++;
          if (ch >= target.length) { dir = -1; setTimeout(step, 1800); return; }
        } else {
          ch--;
          if (ch <= 0) { dir = 1; idx = (idx + 1) % nextDrafts.length; setTimeout(step, 500); return; }
        }
        typedEl.textContent = target.slice(0, ch);
        setTimeout(step, dir > 0 ? 55 : 28);
      };
      step();
    }
  }
</script>

<style>
  .clock {
    background: linear-gradient(180deg, #0c1114 0%, #0a0d0f 100%);
    border: 1px solid var(--rule-2);
    box-shadow:
      inset 0 0 0 1px rgba(255, 180, 84, 0.08),
      0 40px 100px -40px rgba(255, 180, 84, 0.35),
      0 0 80px -20px rgba(255, 180, 84, 0.15);
    font-family: var(--mono);
    overflow: hidden;
  }
  .clock-chrome {
    display: flex; align-items: center; gap: 14px;
    padding: 11px 16px;
    background: #08090b;
    border-bottom: 1px solid var(--rule-2);
    font-size: 11px;
    color: var(--phosphor-dim);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .dots { display: inline-flex; gap: 6px; }
  .d { width: 9px; height: 9px; border-radius: 50%; display: inline-block; opacity: 0.7; }
  .d-r { background: var(--red); }
  .d-y { background: var(--phosphor); }
  .d-g { background: var(--green); }
  .title { letter-spacing: 0.08em; }
  .badge {
    margin-left: auto;
    color: var(--phosphor);
    border: 1px solid var(--phosphor-dim);
    padding: 3px 8px;
    font-size: 10px;
    letter-spacing: 0.16em;
  }

  /* Screen is a flex column so the prompt can hard-pin to the bottom */
  .screen {
    position: relative;
    display: flex; flex-direction: column;
    min-height: 380px;
    padding: 0;
  }
  /* Idle animation ported from src/components/SaiLogo.css (mode="idle").
     Two stacked loops: a slow vertical float and a breathing drop-shadow.
     :global() because the SVG renders inside SaiMark and carries that
     component's Astro scope, not MissionClock's. */
  :global(.drift-logo) {
    position: absolute;
    top: 50%; left: 50%;
    width: 320px; height: 320px;
    max-width: 70%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    color: var(--phosphor);
    opacity: 0.12;
    z-index: 0;
    animation:
      drift-float-y 4s ease-in-out infinite,
      drift-breathe 5s ease-in-out infinite;
  }
  @keyframes drift-float-y {
    0%, 100% { translate: 0 -4%; }
    50%      { translate: 0  4%; }
  }
  @keyframes drift-breathe {
    0%, 100% { filter: drop-shadow(0 0 12px rgba(255, 180, 84, 0.30)); }
    50%      { filter: drop-shadow(0 0 32px rgba(255, 180, 84, 0.75)); }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.drift-logo) {
      animation: none;
      filter: drop-shadow(0 0 18px rgba(255, 180, 84, 0.5));
    }
  }
  .scan {
    position: absolute; inset: 0; pointer-events: none; z-index: 1;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 3px,
      rgba(0,0,0,0.20) 3px,
      rgba(0,0,0,0.20) 4px
    );
    mix-blend-mode: multiply;
  }

  /* Chat: flex:1 so it grows; prompt at bottom uses margin-top:auto */
  .chat {
    position: relative;
    z-index: 2;
    flex: 1;
    padding: 28px 28px 20px;
    display: flex; flex-direction: column; gap: 18px;
    overflow: hidden;
  }
  .msg { display: grid; grid-template-columns: 60px 1fr; column-gap: 14px; align-items: baseline; }
  .who {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--phosphor-dim);
    padding-top: 2px;
  }
  .msg.user .body {
    color: var(--phosphor-2);
    font-size: 14px; line-height: 1.55;
  }
  .msg.user .body::before {
    content: "› ";
    color: var(--phosphor-dim);
  }
  .msg.assistant .who { color: var(--phosphor); }

  /* Matches src/components/Chat/ChatPanel.tsx — the real SAI thinking row. */
  .thinking-animation {
    display: flex; align-items: center; gap: 8px;
    min-height: 40px;
  }
  .thinking-icon {
    width: 18px; height: 18px;
    flex-shrink: 0;
    filter: drop-shadow(0 0 6px var(--phosphor-glow));
    animation: thinking-pulse 2.4s ease-in-out infinite;
  }
  @keyframes thinking-pulse {
    0%, 100% { transform: scale(1);    opacity: 0.85; }
    50%      { transform: scale(1.12); opacity: 1; }
  }
  .thinking-clock {
    font-variant-numeric: tabular-nums;
    font-size: 11px;
    color: var(--phosphor-dim);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .thinking-text {
    font-size: 13px;
    line-height: 1;
    color: var(--phosphor);
    font-weight: 400;
    letter-spacing: 0.4px;
  }
  .thinking-cursor-block {
    display: inline-block;
    width: 0.55em;
    height: 1em;
    background: currentColor;
    vertical-align: -0.15em;
    margin-left: 3px;
    animation: thinking-cursor-blink 1s steps(1) infinite;
  }
  @keyframes thinking-cursor-blink {
    0%, 49%   { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .thinking-cursor-block, .thinking-icon { animation: none; opacity: 1; }
  }

  .cursor { color: var(--phosphor); animation: blink 1s steps(2, start) infinite; }

  /* Hard-locked to the bottom */
  .prompt {
    position: relative; z-index: 2;
    margin-top: auto;
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    column-gap: 10px;
    padding: 16px 22px;
    background: rgba(0, 0, 0, 0.35);
    border-top: 1px solid var(--rule-2);
    font-size: 13.5px;
    color: var(--phosphor-2);
  }
  .prompt .caret {
    color: var(--phosphor);
    font-size: 16px;
    line-height: 1;
  }
  .prompt .input {
    min-height: 1.4em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: clip;
  }
  .input-cursor { font-size: 14px; }
  .prompt .kbd {
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--phosphor-dim);
    border: 1px solid var(--phosphor-dim);
    padding: 4px 8px;
    line-height: 0;
  }
  .prompt .kbd :global(svg) { width: 14px; height: 14px; stroke-width: 1.75; }

  @media (max-width: 720px) {
    .chat { padding: 22px 18px 14px; }
    .msg { grid-template-columns: 48px 1fr; column-gap: 10px; }
    .prompt { padding: 14px 18px; }
    .drift-logo { width: 240px; height: 240px; }
  }
</style>
